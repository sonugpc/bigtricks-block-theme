{
	"$schema": "https://schemas.wp.org/trunk/block.json",
	"apiVersion": 3,
	"name": "bigtricks/contact-form",
	"version": "1.0.0",
	"title": "Contact Form",
	"category": "widgets",
	"icon": "email",
	"description": "A customizable contact form that sends email to site admin",
	"keywords": ["contact", "form", "email"],
	"textdomain": "bigtricks",
	"supports": {
		"html": false,
		"align": ["wide", "full"],
		"spacing": {
			"margin": true,
			"padding": true
		},
		"color": {
			"background": true,
			"text": true,
			"gradients": true
		},
		"typography": {
			"fontSize": true,
			"lineHeight": true
		}
	},
	"attributes": {
		"formTitle": {
			"type": "string",
			"default": "Get in Touch"
		},
		"formDescription": {
			"type": "string",
			"default": "Have a question? We'd love to hear from you. Send us a message and we'll respond as soon as possible."
		},
		"submitButtonText": {
			"type": "string",
			"default": "Send Message"
		},
		"successMessage": {
			"type": "string",
			"default": "Thank you! Your message has been sent successfully."
		},
		"showTitle": {
			"type": "boolean",
			"default": true
		},
		"showDescription": {
			"type": "boolean",
			"default": true
		}
	},
	"render": "file:./render.php"
}
